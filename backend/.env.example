# ============================================================
# Axis — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://axis:axis@localhost:5432/axis

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- GitLab ---
GITLAB_URL=https://gitlab.com
GITLAB_APP_ID=your_gitlab_app_id
GITLAB_APP_SECRET=your_gitlab_app_secret

# --- Google Gemini (for embeddings + LLM) ---
GEMINI_API_KEY=your_gemini_api_key

# --- App ---
SECRET_KEY=change-me-to-a-random-string
APP_URL=http://localhost:5173
API_URL=http://localhost:8000

# --- Qdrant (vector search) ---
QDRANT_URL=http://localhost:6333

# --- Embedding Config ---
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- LangSmith (Optional — for end-to-end RAG pipeline tracing) ---
# Get your API key at https://smith.langchain.com (free tier available)
# Leave empty to disable tracing gracefully
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=axis-rag
LANGCHAIN_TRACING_V2=true

# --- RAGAS Evaluation (uses your existing Gemini API key as the judge LLM) ---
RAGAS_ENABLED=true
RAGAS_EVAL_MODEL=gemini-2.0-flash

# --- Advanced Retrieval Strategies ---
STEP_BACK_PROMPTING_ENABLED=true
CONTEXTUAL_COMPRESSION_ENABLED=true
CONTEXTUAL_COMPRESSION_THRESHOLD=0.6
PARENT_DOCUMENT_RETRIEVAL_ENABLED=true
