# ============================================================
# Clarity — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://clarity:clarity@localhost:5432/clarity

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- GitLab ---
GITLAB_URL=https://gitlab.com
GITLAB_APP_ID=your_gitlab_app_id
GITLAB_APP_SECRET=your_gitlab_app_secret

# --- Google Gemini (for embeddings + LLM) ---
GEMINI_API_KEY=your_gemini_api_key

# --- App ---
SECRET_KEY=change-me-to-a-random-string
APP_URL=http://localhost:5173
API_URL=http://localhost:8000

# --- Embedding Config ---
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
